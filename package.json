{
  "name": "fitpal",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "@biomejs/biome format --write .",
    "db:generate": "bun run --cwd packages/database generate",
    "db:migrate": "bun run --cwd packages/database migrate",
    "db:push": "bun run --cwd packages/database push"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5",
    "@biomejs/biome": "^1"
  },
  "packageManager": "bun@1.3.14"
}
